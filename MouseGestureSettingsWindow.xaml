<Window x:Class="LuminaDesktop.MouseGestureSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mouse Gestures Settings" Height="500" Width="600"
        Loaded="Window_Loaded" Closed="Window_Closed"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI" FontSize="14"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#1E1E1E" CornerRadius="10" BorderBrush="#333" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="Transparent" Height="40">
                <TextBlock Text="Mouse Gestures Settings" Foreground="#AAA" VerticalAlignment="Center" Margin="15,0,0,0" FontSize="12" FontWeight="SemiBold"/>
                <Button Content="✕" Width="40" HorizontalAlignment="Right" Background="Transparent" Foreground="#AAA" BorderThickness="0" FontSize="14" Click="BtnClose_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="20,10,20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Process List -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Applications" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    
                    <ListBox x:Name="lstProcesses" Grid.Row="1" Background="#252526" Foreground="White" BorderBrush="#333" BorderThickness="1" 
                             SelectionChanged="LstProcesses_SelectionChanged" Margin="0,0,0,10">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="Margin" Value="0,1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#007ACC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtNewProcess" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,5,0" Padding="6,2" ToolTip="e.g. chrome.exe" VerticalContentAlignment="Center" Height="34"/>
                        <Button Grid.Column="1" Content="+" Style="{StaticResource ModernButtonStyle}" Width="34" Height="34" Padding="0" Click="BtnAddProcess_Click" ToolTip="Add Application"/>
                        <Button Grid.Column="2" Content="-" Style="{StaticResource ModernButtonStyle}" Width="34" Height="34" Padding="0" Margin="5,0,0,0" Click="BtnRemoveProcess_Click" ToolTip="Remove Application"/>
                    </Grid>
                </Grid>

                <!-- Right Panel: Gestures List -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="txtSelectedProcessTitle" Text="Gestures" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <Border Grid.Row="1" Background="#252526" BorderBrush="#333" BorderThickness="1" Margin="0,0,0,10">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="icGestures">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="10,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Key}" Foreground="#AAA" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Value}" Foreground="White" VerticalAlignment="Center"/>
                                            <Button Grid.Column="3" Content="✕" Width="25" Height="25" Background="Transparent" Foreground="#AAA" BorderThickness="0" 
                                                    Click="BtnRemoveGesture_Click" Tag="{Binding Key}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- Add Gesture Form -->
                    <Border Grid.Row="2" Background="#252526" BorderBrush="#333" BorderThickness="1" Padding="10" CornerRadius="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Text="Direction (e.g. Left)" Foreground="#AAA" FontSize="12" Margin="0,0,0,5"/>
                            <TextBlock Grid.Column="2" Text="Hotkey (e.g. Alt+Left)" Foreground="#AAA" FontSize="12" Margin="0,0,0,5"/>
                            
                            <ComboBox x:Name="cmbNewDirection" Grid.Row="1" Style="{StaticResource ModernComboBoxStyle}" Height="34" VerticalAlignment="Center">
                                <ComboBoxItem Content="Left" IsSelected="True"/>
                                <ComboBoxItem Content="Right"/>
                                <ComboBoxItem Content="Up"/>
                                <ComboBoxItem Content="Down"/>
                                <ComboBoxItem Content="Up,Right"/>
                                <ComboBoxItem Content="Up,Left"/>
                                <ComboBoxItem Content="Down,Right"/>
                                <ComboBoxItem Content="Down,Left"/>
                            </ComboBox>
                            <TextBox x:Name="txtNewHotkey" Grid.Row="1" Grid.Column="2" Style="{StaticResource ModernTextBoxStyle}" Padding="6,2" Margin="0" VerticalContentAlignment="Center" Height="34" VerticalAlignment="Center"/>
                            <Button Grid.Row="1" Grid.Column="4" Content="Add" Style="{StaticResource PrimaryButtonStyle}" Width="60" Height="34" Padding="10,6" Click="BtnAddGesture_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

        </Grid>
    </Border>
</Window>
