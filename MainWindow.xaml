<Window x:Class="LuminaDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LuminaDesktop Settings" Height="600" Width="650"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI" FontSize="14"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Border Background="#1E1E1E" CornerRadius="10" BorderBrush="#333" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="Transparent" Height="40">
                <TextBlock Text="LuminaDesktop" Foreground="#AAA" VerticalAlignment="Center" Margin="15,0,0,0" FontSize="12" FontWeight="SemiBold"/>
                <Button Content="✕" Width="40" HorizontalAlignment="Right" Background="Transparent" Foreground="#AAA" BorderThickness="0" FontSize="14" Click="BtnCancel_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
            
            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" BorderThickness="0">
                <Grid Margin="30,10,30,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Settings" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,0,0,25"/>
                    
                    <StackPanel Grid.Row="1">
                        <!-- General Settings Card -->
                        <Border Background="#252526" CornerRadius="8" Padding="20" Margin="0,0,0,20" BorderBrush="#333" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="General" Foreground="#AAAAAA" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                <CheckBox x:Name="chkStartWithWindows" Content="Start with Windows" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,15"/>
                                <CheckBox x:Name="chkStartAsAdmin" Content="Start as Administrator" Style="{StaticResource ToggleSwitchStyle}"/>
                            </StackPanel>
                        </Border>

                        <!-- Modules Card -->
                        <Border Background="#252526" CornerRadius="8" Padding="20" BorderBrush="#333" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Modules" Foreground="#AAAAAA" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                <CheckBox x:Name="chkMousewarp" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Mousewarp" Foreground="White" FontWeight="SemiBold"/>
                                        <TextBlock Text="Move cursor to center of active window on Alt+Tab" Foreground="#888" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </CheckBox>
                                <CheckBox x:Name="chkBws" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Better Window Switcher" Foreground="White" FontWeight="SemiBold"/>
                                        <TextBlock Text="High performance Alt+Tab replacement" Foreground="#888" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </CheckBox>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="chkLumaEdges" Style="{StaticResource ToggleSwitchStyle}">
                                        <StackPanel>
                                            <TextBlock Text="LumaEdges" Foreground="White" FontWeight="SemiBold"/>
                                            <TextBlock Text="Screen edge hotkeys" Foreground="#888" FontSize="12" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </CheckBox>
                                    <Button Grid.Column="1" Content="⚙" Width="30" Height="30" FontSize="16" Style="{StaticResource ModernButtonStyle}" Padding="0" Click="BtnLumaEdgesSettings_Click" ToolTip="LumaEdges Settings" VerticalAlignment="Top"/>
                                </Grid>
                                <Grid Margin="0,15,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="chkMouseGestures" Style="{StaticResource ToggleSwitchStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Mouse Gestures" Foreground="White" FontWeight="SemiBold"/>
                                            <TextBlock Text="Right-click drag gestures per application" Foreground="#888" FontSize="12" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </CheckBox>
                                    <Button Grid.Column="1" Content="⚙" Width="30" Height="30" FontSize="16" Style="{StaticResource ModernButtonStyle}" Padding="0" Click="BtnMouseGesturesSettings_Click" ToolTip="Mouse Gestures Settings" VerticalAlignment="Top"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
            
            <!-- Footer -->
            <Border Grid.Row="2" Background="#2D2D30" CornerRadius="0,0,10,10" Padding="20,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnCancel" Content="Cancel" Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,0" Width="90" Click="BtnCancel_Click"/>
                    <Button x:Name="btnSave" Content="Save &amp; Apply" Style="{StaticResource PrimaryButtonStyle}" Width="120" Click="BtnSave_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
