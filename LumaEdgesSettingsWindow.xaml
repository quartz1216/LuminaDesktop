<Window x:Class="LuminaDesktop.LumaEdgesSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:LuminaDesktop.Controls"
        Title="LumaEdges Settings" Height="750" Width="500"
        Loaded="Window_Loaded" Closed="Window_Closed"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI" FontSize="14"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Border Background="#1E1E1E" CornerRadius="10" BorderBrush="#333" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="Transparent" Height="40">
                <TextBlock Text="LumaEdges Settings" Foreground="#AAA" VerticalAlignment="Center" Margin="15,0,0,0" FontSize="12" FontWeight="SemiBold"/>
                <Button Content="✕" Width="40" HorizontalAlignment="Right" Background="Transparent" Foreground="#AAA" BorderThickness="0" FontSize="14" Click="BtnCancel_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
            
            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" BorderThickness="0">
                <StackPanel Margin="30,20,40,20">
                    <TextBlock Text="General" Foreground="#AAAAAA" FontWeight="SemiBold" Margin="0,0,0,25"/>
                    <Grid Margin="0,0,0,35">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Edge Thickness:" Foreground="White" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <Slider x:Name="sldThickness" Style="{StaticResource ModernSliderStyle}" Grid.Column="1" Minimum="1" Maximum="20" Value="2" VerticalAlignment="Center" ValueChanged="sldThickness_ValueChanged"/>
                    </Grid>

                    <TextBlock Text="Hotkeys (Zones)" Foreground="#AAAAAA" FontWeight="SemiBold" Margin="0,0,0,15"/>
                    <TextBlock Text="Leave empty to allow normal click-through." Foreground="#888888" FontSize="12" Margin="0,0,0,20"/>
                    
                    <TabControl Margin="0,0,0,20">
                        <TabItem Header="Left Button">
                            <StackPanel Margin="0,15,0,0">
                                <TextBlock Text="Edges" Foreground="#AAAAAA" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <Grid Margin="10,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="0" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="Top" Margin="0,0,8,0"/><TextBlock Text="Top:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtLeftTop" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="0" Grid.Column="1" Margin="0,0,0,15"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="1" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="Bottom" Margin="0,0,8,0"/><TextBlock Text="Bottom:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtLeftBottom" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="1" Grid.Column="1" Margin="0,0,0,15"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="2" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="Left" Margin="0,0,8,0"/><TextBlock Text="Left:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtLeftLeft" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="2" Grid.Column="1" Margin="0,0,0,15"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="3" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="Right" Margin="0,0,8,0"/><TextBlock Text="Right:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtLeftRight" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="3" Grid.Column="1" Margin="0,0,0,15"/>
                                </Grid>
                                <TextBlock Text="Corners" Foreground="#AAAAAA" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <Grid Margin="10,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="0" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="TopLeft" Margin="0,0,8,0"/><TextBlock Text="TopLeft:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtLeftTopLeft" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="0" Grid.Column="1" Margin="0,0,0,15"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="1" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="TopRight" Margin="0,0,8,0"/><TextBlock Text="TopRight:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtLeftTopRight" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="1" Grid.Column="1" Margin="0,0,0,15"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="2" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="BottomLeft" Margin="0,0,8,0"/><TextBlock Text="BottomLeft:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtLeftBottomLeft" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="2" Grid.Column="1" Margin="0,0,0,15"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="3" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="BottomRight" Margin="0,0,8,0"/><TextBlock Text="BottomRight:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtLeftBottomRight" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="3" Grid.Column="1" Margin="0,0,0,15"/>
                                </Grid>
                            </StackPanel>
                        </TabItem>
                        <TabItem Header="Right Button">
                            <StackPanel Margin="0,15,0,0">
                                <TextBlock Text="Edges" Foreground="#AAAAAA" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <Grid Margin="10,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="0" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="Top" Margin="0,0,8,0"/><TextBlock Text="Top:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtRightTop" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="0" Grid.Column="1" Margin="0,0,0,15"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="1" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="Bottom" Margin="0,0,8,0"/><TextBlock Text="Bottom:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtRightBottom" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="1" Grid.Column="1" Margin="0,0,0,15"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="2" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="Left" Margin="0,0,8,0"/><TextBlock Text="Left:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtRightLeft" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="2" Grid.Column="1" Margin="0,0,0,15"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="3" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="Right" Margin="0,0,8,0"/><TextBlock Text="Right:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtRightRight" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="3" Grid.Column="1" Margin="0,0,0,15"/>
                                </Grid>
                                <TextBlock Text="Corners" Foreground="#AAAAAA" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <Grid Margin="10,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="0" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="TopLeft" Margin="0,0,8,0"/><TextBlock Text="TopLeft:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtRightTopLeft" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="0" Grid.Column="1" Margin="0,0,0,15"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="1" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="TopRight" Margin="0,0,8,0"/><TextBlock Text="TopRight:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtRightTopRight" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="1" Grid.Column="1" Margin="0,0,0,15"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="2" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="BottomLeft" Margin="0,0,8,0"/><TextBlock Text="BottomLeft:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtRightBottomLeft" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="2" Grid.Column="1" Margin="0,0,0,15"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="3" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="BottomRight" Margin="0,0,8,0"/><TextBlock Text="BottomRight:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtRightBottomRight" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="3" Grid.Column="1" Margin="0,0,0,15"/>
                                </Grid>
                            </StackPanel>
                        </TabItem>
                        <TabItem Header="Middle Button">
                            <StackPanel Margin="0,15,0,0">
                                <TextBlock Text="Edges" Foreground="#AAAAAA" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <Grid Margin="10,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="0" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="Top" Margin="0,0,8,0"/><TextBlock Text="Top:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtMiddleTop" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="0" Grid.Column="1" Margin="0,0,0,15"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="1" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="Bottom" Margin="0,0,8,0"/><TextBlock Text="Bottom:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtMiddleBottom" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="1" Grid.Column="1" Margin="0,0,0,15"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="2" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="Left" Margin="0,0,8,0"/><TextBlock Text="Left:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtMiddleLeft" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="2" Grid.Column="1" Margin="0,0,0,15"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="3" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="Right" Margin="0,0,8,0"/><TextBlock Text="Right:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtMiddleRight" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="3" Grid.Column="1" Margin="0,0,0,15"/>
                                </Grid>
                                <TextBlock Text="Corners" Foreground="#AAAAAA" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <Grid Margin="10,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="0" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="TopLeft" Margin="0,0,8,0"/><TextBlock Text="TopLeft:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtMiddleTopLeft" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="0" Grid.Column="1" Margin="0,0,0,15"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="1" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="TopRight" Margin="0,0,8,0"/><TextBlock Text="TopRight:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtMiddleTopRight" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="1" Grid.Column="1" Margin="0,0,0,15"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="2" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="BottomLeft" Margin="0,0,8,0"/><TextBlock Text="BottomLeft:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtMiddleBottomLeft" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="2" Grid.Column="1" Margin="0,0,0,15"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="3" Margin="0,0,10,15"><controls:PositionIcon ActivePosition="BottomRight" Margin="0,0,8,0"/><TextBlock Text="BottomRight:" Foreground="White" VerticalAlignment="Center"/></StackPanel><TextBox x:Name="txtMiddleBottomRight" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="3" Grid.Column="1" Margin="0,0,0,15"/>
                                </Grid>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#2D2D30" CornerRadius="0,0,10,10" Padding="20,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,0" Width="80" Click="BtnCancel_Click"/>
                    <Button Content="Save" Style="{StaticResource PrimaryButtonStyle}" Width="80" Click="BtnSave_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
