<Window x:Class="LuminaDesktop.LumaEdgesSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LumaEdges Settings" Height="500" Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI" FontSize="14"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Window.Resources>
        <!-- Style definitions similar to MainWindow -->
        <Style TargetType="Button" x:Key="ModernButtonStyle">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4E4E52"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2E2E32"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryButtonStyle" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#007ACC"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0098FF"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox" x:Key="ModernTextBoxStyle">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Border Background="#1E1E1E" CornerRadius="10" BorderBrush="#333" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="Transparent" Height="40">
                <TextBlock Text="LumaEdges Settings" Foreground="#AAA" VerticalAlignment="Center" Margin="15,0,0,0" FontSize="12" FontWeight="SemiBold"/>
                <Button Content="✕" Width="40" HorizontalAlignment="Right" Background="Transparent" Foreground="#AAA" BorderThickness="0" FontSize="14" Click="BtnCancel_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E81123"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
            
            <!-- Content -->
            <ScrollViewer Grid.Row="1" Margin="20,10,20,10" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="General" Foreground="#AAAAAA" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Edge Thickness:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Slider x:Name="sldThickness" Grid.Column="1" Minimum="1" Maximum="20" Value="2" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Trigger Button:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="cmbTriggerButton" Grid.Column="1" VerticalAlignment="Center" Background="#3E3E42" Foreground="Black">
                            <ComboBoxItem Content="Left"/>
                            <ComboBoxItem Content="Right"/>
                            <ComboBoxItem Content="Middle"/>
                        </ComboBox>
                    </Grid>

                    <TextBlock Text="Hotkeys (Zones)" Foreground="#AAAAAA" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Top:" Foreground="White" VerticalAlignment="Center" Grid.Row="0"/>
                        <TextBox x:Name="txtTop" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="0" Grid.Column="1"/>

                        <TextBlock Text="Bottom:" Foreground="White" VerticalAlignment="Center" Grid.Row="1"/>
                        <TextBox x:Name="txtBottom" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="1" Grid.Column="1"/>

                        <TextBlock Text="Left:" Foreground="White" VerticalAlignment="Center" Grid.Row="2"/>
                        <TextBox x:Name="txtLeft" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="2" Grid.Column="1"/>

                        <TextBlock Text="Right:" Foreground="White" VerticalAlignment="Center" Grid.Row="3"/>
                        <TextBox x:Name="txtRight" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="3" Grid.Column="1"/>

                        <TextBlock Text="TopLeft:" Foreground="White" VerticalAlignment="Center" Grid.Row="4"/>
                        <TextBox x:Name="txtTopLeft" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="4" Grid.Column="1"/>

                        <TextBlock Text="TopRight:" Foreground="White" VerticalAlignment="Center" Grid.Row="5"/>
                        <TextBox x:Name="txtTopRight" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="5" Grid.Column="1"/>

                        <TextBlock Text="BottomLeft:" Foreground="White" VerticalAlignment="Center" Grid.Row="6"/>
                        <TextBox x:Name="txtBottomLeft" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="6" Grid.Column="1"/>

                        <TextBlock Text="BottomRight:" Foreground="White" VerticalAlignment="Center" Grid.Row="7"/>
                        <TextBox x:Name="txtBottomRight" Style="{StaticResource ModernTextBoxStyle}" Grid.Row="7" Grid.Column="1"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#2D2D30" CornerRadius="0,0,10,10" Padding="20,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,0" Width="80" Click="BtnCancel_Click"/>
                    <Button Content="Save" Style="{StaticResource PrimaryButtonStyle}" Width="80" Click="BtnSave_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
